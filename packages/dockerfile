FROM ubuntu:18.04

# Отключаем интерактивные запросы при установке
ENV DEBIAN_FRONTEND=noninteractive

# Обновляем систему и ставим только необходимое для сборки
RUN apt-get update && apt-get install -y \
    build-essential \
    wget \
    ca-certificates \
    libssl-dev \
    zlib1g \
    zlib1g-dev \
    rpm \
    && rm -rf /var/lib/apt/lists/*

# Используем прямую ссылку на официальный сайт CMake (там меньше проблем с редиректами)
# Версия 3.26.4 стабильна и работает на 18.04
RUN wget --no-check-certificate https://github.com/Kitware/CMake/releases/download/v3.26.4/cmake-3.26.4-linux-x86_64.tar.gz \
    && tar -xzf cmake-3.26.4-linux-x86_64.tar.gz --strip-components=1 -C /usr/local \
    && rm cmake-3.26.4-linux-x86_64.tar.gz

# Проверяем инструменты
RUN cmake --version && g++ --version

WORKDIR /builder
